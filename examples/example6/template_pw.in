&CONTROL
  calculation = 'relax',
  prefix = 'MgZnO',
  outdir = './out',
  pseudo_dir = './',
/
&SYSTEM
  ibrav = 0,
  nat = 16,
  ntyp = 3,
  ecutwfc = 60.0,
  ecutrho = 480.0,
/
&ELECTRONS
  conv_thr = 1.0d-8,
/
&IONS
  ion_dynamics = 'bfgs',
/
ATOMIC_SPECIES
  Mg  24.305  Mg.upf
  Zn  65.38   Zn.upf
  O   15.999  O.upf

@configuration_structure@

K_POINTS automatic
  3 3 4  0 0 0
