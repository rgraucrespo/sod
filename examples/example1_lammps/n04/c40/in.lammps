units           metal
dimension       3
boundary        p p p
atom_style      full

read_data       conf.data

pair_style      buck/coul/long 10.0
bond_style      harmonic
kspace_style    pppm 1.0e-5

mass            1 58.6934
mass            2 24.3050
mass            3 15.9994
mass            4 0.0

set             type 1 charge -1.344
set             type 2 charge  2.0
set             type 3 charge  0.86902
set             type 4 charge -2.86902

pair_coeff      1 3  1582.5  0.28820  0.0
pair_coeff      2 3   946.627 0.31813  0.0
pair_coeff      3 3 22764.0  0.14900 27.879

bond_coeff      1 74.92 0.0


minimize        1.0e-12 1.0e-12 1000 10000
